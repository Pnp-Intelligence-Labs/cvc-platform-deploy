# Railway environment variables for the API service.
# Set these in the Railway dashboard under your service → Variables.
# Variable references use Railway's ${{Plugin.VAR}} syntax.

# ── Runtime ──────────────────────────────────────────────────────────────────
ENVIRONMENT=production
PYTHONPATH=/app:/app/core

# PORT is injected automatically by Railway — do not set manually.

# ── Database (Supabase) ───────────────────────────────────────────────────────
# In Supabase: Settings → Database → Connection string → URI tab.
# IMPORTANT: Use the DIRECT connection string (port 5432), NOT the Supabase
# pooler (port 6543). The app uses session-level SET commands that require a
# persistent session incompatible with pgbouncer transaction mode.
#
# The URI already includes sslmode=require — no extra SSL env var needed.
DATABASE_URL=postgresql://postgres:<password>@db.<ref>.supabase.co:5432/postgres

# Schema used by the app (default: cvc)
APP_SCHEMA=cvc

# ── Auth ──────────────────────────────────────────────────────────────────────
# Generate: openssl rand -hex 32
JWT_SECRET=CHANGE_ME

# Comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=https://your-frontend.vercel.app
ALLOW_CREDENTIALS=true

# Roles that must enroll MFA (comma-separated)
MFA_REQUIRED_ROLES=GP,PSM,Ventures

# ── Object storage (Cloudflare R2 — recommended) ─────────────────────────────
# R2 speaks the S3/MinIO API. No code changes required.
# Create a bucket at dash.cloudflare.com → R2 → Create bucket.
# Then create an API token with Object Read & Write for that bucket.
#
# Endpoint format: <account_id>.r2.cloudflarestorage.com  (no port, no scheme)
MINIO_ENDPOINT=<account_id>.r2.cloudflarestorage.com
MINIO_ACCESS_KEY=CHANGE_ME
MINIO_SECRET_KEY=CHANGE_ME
MINIO_BUCKET=platform-documents
MINIO_SECURE=true

# ── Optional plugin keys ──────────────────────────────────────────────────────
OPENROUTER_API_KEY=
BRAVE_API_KEY=
PROXYCURL_API_KEY=

# ── Upload limits ─────────────────────────────────────────────────────────────
MAX_UPLOAD_MB=25
