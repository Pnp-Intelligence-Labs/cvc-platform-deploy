# Copy this to .env and fill in values — never commit .env

# ── Database ──────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=platform_db
DB_USER=platform
DB_PASSWORD=

# ── API ───────────────────────────────────────────────────────────────────────
JWT_SECRET=
PORT=8002
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:8002
ALLOW_CREDENTIALS=false

# ── Plugins (only needed if plugins are installed) ────────────────────────────
# OPENROUTER_API_KEY=
# BRAVE_API_KEY=
# PROXYCURL_API_KEY=
