# Copy this to .env and fill in values — never commit .env

# ── Database ──────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=platform_db
DB_USER=platform
DB_PASSWORD=

# ── API ───────────────────────────────────────────────────────────────────────
JWT_SECRET=
PORT=8002
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:8002
ALLOW_CREDENTIALS=false

# ── Object storage (MinIO) ────────────────────────────────────────────────────
# Run via docker-compose — defaults below work for local dev
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=platform
MINIO_SECRET_KEY=platform_local
MINIO_BUCKET=platform-documents
MINIO_SECURE=false
# In Docker Compose (production), set MINIO_ENDPOINT=minio:9000

# ── Google OAuth (optional — enables "Sign in with Google" on login page) ────
# Create credentials at console.cloud.google.com → APIs & Services → Credentials
# Set authorized redirect URI to: http://your-domain/auth/google/callback
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_ALLOWED_DOMAIN=yourdomain.com   # restrict to one domain, leave blank for any Google account
# APP_BASE_URL=http://localhost:8002      # public base URL, no trailing slash

# ── Plugins (only needed if plugins are installed) ────────────────────────────
# OPENROUTER_API_KEY=
# BRAVE_API_KEY=
# PROXYCURL_API_KEY=

# ── Docker mode note ──────────────────────────────────────────────────────────
# docker-compose up --build
#   → Runs the full stack in containers (API + Postgres).
#     DB_HOST must be "db" (the compose service name), not "localhost".
#     The entrypoint waits for Postgres, runs migrations, then starts uvicorn.
#
# bash scripts/run_local.sh
#   → Local dev: starts Postgres in Docker, runs the API directly on the host
#     with hot-reload. DB_HOST stays "localhost" (port-forwarded by Docker).
#     Use this when actively developing — faster iteration, no image rebuild.
