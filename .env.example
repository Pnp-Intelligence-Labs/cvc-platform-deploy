# Copy this to .env and fill in values — never commit .env

# ── Database ──────────────────────────────────────────────────────────────────
# Option A — single URI (Supabase / Railway / any cloud provider):
#   DATABASE_URL=postgresql://postgres:<password>@db.<ref>.supabase.co:5432/postgres
#   When set, DATABASE_URL takes precedence over the individual DB_* vars below.
#   Use the DIRECT connection (port 5432), NOT the Supabase pooler (port 6543) —
#   the app sets session-level GUCs (search_path, audit_source) that require a
#   persistent session and are incompatible with pgbouncer transaction mode.
DATABASE_URL=

# Option B — individual vars (local Docker dev):
DB_HOST=localhost
DB_PORT=5432
DB_NAME=platform_db
DB_USER=platform
DB_PASSWORD=

# ── API ───────────────────────────────────────────────────────────────────────
JWT_SECRET=
PORT=8002
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:8002
ALLOW_CREDENTIALS=false

# ── Object storage (MinIO) ────────────────────────────────────────────────────
# Run via docker-compose — defaults below work for local dev
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=platform
MINIO_SECRET_KEY=CHANGE_ME   # generated by install.sh; never leave as default in production
MINIO_BUCKET=platform-documents
MINIO_SECURE=false
# In Docker Compose (production), set MINIO_ENDPOINT=minio:9000

# ── Google OAuth (optional — enables "Sign in with Google" on login page) ────
# Create credentials at console.cloud.google.com → APIs & Services → Credentials
# Set authorized redirect URI to: http://your-domain/auth/google/callback
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_ALLOWED_DOMAIN=yourdomain.com   # restrict to one domain, leave blank for any Google account
# APP_BASE_URL=http://localhost:8002      # public base URL, no trailing slash

# ── Plugins (only needed if plugins are installed) ────────────────────────────
# OPENROUTER_API_KEY=
# BRAVE_API_KEY=
# PROXYCURL_API_KEY=

# ── Security / Compliance ─────────────────────────────────────────────────────
# Max file upload size in megabytes (default 25). Applies to all uploads.
MAX_UPLOAD_MB=25

# Roles that must use MFA to log in (comma-separated). Empty = no enforcement.
# Users in listed roles are blocked from logging in until they enroll a TOTP app.
MFA_REQUIRED_ROLES=GP,PSM,Ventures

# Issuer name shown in authenticator apps for TOTP codes.
MFA_ISSUER=Platform

# Enable HIBP (HaveIBeenPwned) password check on user creation / password change.
# Set to false to skip the check (e.g., air-gapped deployments with no internet).
HIBP_CHECK_ENABLED=true

# Data classification mode for outbound LLM/API calls.
# strict  — any call with data_class=confidential/restricted requires pii_stripped=True
# permissive — log and allow all calls regardless of classification
DATA_CLASSIFICATION_MODE=permissive

# Log level for structured request logs: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# ClamAV virus scanning on file uploads (optional)
# CLAMAV_ENABLED=false
# CLAMAV_HOST=clamav
# CLAMAV_PORT=3310

# Grafana admin password (for docker-compose.logging.yml overlay)
# GRAFANA_ADMIN_PASSWORD=changeme

# ── Keycloak (optional — for OIDC auth) ──────────────────────────────────────
# KEYCLOAK_URL=http://localhost:8080
# KEYCLOAK_REALM=platform
# KEYCLOAK_CLIENT_ID=platform-api
# KEYCLOAK_CLIENT_SECRET=
# KEYCLOAK_ROLE_CLAIM=realm_access.roles  # dot-notation — resolves to the roles list directly
# KEYCLOAK_ROLE_CLAIM=realm_access        # dict claim — code reads the nested "roles" key
# KEYCLOAK_ROLE_CLAIM=groups              # flat group-membership list claim
# KEYCLOAK_DEFAULT_ROLE=Ventures

# ── Google Drive (optional) ───────────────────────────────────────────────────
# GDRIVE_CREDS_PATH=config/gdrive_credentials.json

# ── Ollama (optional — local LLM) ────────────────────────────────────────────
# OLLAMA_URL=http://localhost:11434
# OLLAMA_MODEL=llama3

# ── Django backend (port 8003 — runs alongside FastAPI during migration) ──────
# DJANGO_SECRET_KEY=  # generate: python -c "import secrets; print(secrets.token_urlsafe(50))"

# ── Docker mode note ──────────────────────────────────────────────────────────
# docker-compose up --build
#   → Runs the full stack in containers (API + Postgres).
#     DB_HOST must be "db" (the compose service name), not "localhost".
#     The entrypoint waits for Postgres, runs migrations, then starts uvicorn.
#
# bash scripts/run_local.sh
#   → Local dev: starts Postgres in Docker, runs the API directly on the host
#     with hot-reload. DB_HOST stays "localhost" (port-forwarded by Docker).
#     Use this when actively developing — faster iteration, no image rebuild.
