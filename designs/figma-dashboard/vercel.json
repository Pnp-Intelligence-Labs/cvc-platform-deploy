{
  "buildCommand": "vite build --outDir dist",
  "outputDirectory": "dist",
  "framework": "vite",
  "redirects": [
    { "source": "/", "destination": "/app/", "permanent": false }
  ],
  "rewrites": [
    { "source": "/auth/:path*",          "destination": "https://cvc-api-production.up.railway.app/auth/:path*" },
    { "source": "/companies/:path*",     "destination": "https://cvc-api-production.up.railway.app/companies/:path*" },
    { "source": "/sourcing/:path*",      "destination": "https://cvc-api-production.up.railway.app/sourcing/:path*" },
    { "source": "/shortlists/:path*",    "destination": "https://cvc-api-production.up.railway.app/shortlists/:path*" },
    { "source": "/dealflow/:path*",      "destination": "https://cvc-api-production.up.railway.app/dealflow/:path*" },
    { "source": "/partners/:path*",      "destination": "https://cvc-api-production.up.railway.app/partners/:path*" },
    { "source": "/portfolio/:path*",     "destination": "https://cvc-api-production.up.railway.app/portfolio/:path*" },
    { "source": "/home/:path*",          "destination": "https://cvc-api-production.up.railway.app/home/:path*" },
    { "source": "/admin/:path*",         "destination": "https://cvc-api-production.up.railway.app/admin/:path*" },
    { "source": "/notifications/:path*", "destination": "https://cvc-api-production.up.railway.app/notifications/:path*" },
    { "source": "/ventures/:path*",      "destination": "https://cvc-api-production.up.railway.app/ventures/:path*" },
    { "source": "/requests/:path*",      "destination": "https://cvc-api-production.up.railway.app/requests/:path*" },
    { "source": "/sales/:path*",         "destination": "https://cvc-api-production.up.railway.app/sales/:path*" },
    { "source": "/notes/:path*",         "destination": "https://cvc-api-production.up.railway.app/notes/:path*" },
    { "source": "/health/:path*",        "destination": "https://cvc-api-production.up.railway.app/health/:path*" },
    { "source": "/drive/:path*",         "destination": "https://cvc-api-production.up.railway.app/drive/:path*" },
    { "source": "/terminal/:path*",      "destination": "https://cvc-api-production.up.railway.app/terminal/:path*" },
    { "source": "/config/:path*",        "destination": "https://cvc-api-production.up.railway.app/config/:path*" },
    { "source": "/explore/:path*",       "destination": "https://cvc-api-production.up.railway.app/explore/:path*" },
    { "source": "/enrichment/:path*",    "destination": "https://cvc-api-production.up.railway.app/enrichment/:path*" },
    { "source": "/industrial/:path*",    "destination": "https://cvc-api-production.up.railway.app/industrial/:path*" },
    { "source": "/intel/:path*",         "destination": "https://cvc-api-production.up.railway.app/intel/:path*" },
    { "source": "/lp/:path*",            "destination": "https://cvc-api-production.up.railway.app/lp/:path*" },
    { "source": "/news/:path*",          "destination": "https://cvc-api-production.up.railway.app/news/:path*" },
    { "source": "/reports/:path*",       "destination": "https://cvc-api-production.up.railway.app/reports/:path*" }
  ]
}
